anontweet.duckdns.org {
    reverse_proxy https://localhost:3001 {
        transport http {
            tls_insecure_skip_verify
            read_timeout 86400s
            write_timeout 86400s
        }
        # Keep socket.io / WebSocket connections alive and unbuffered
        header_up Connection {http.request.header.Connection}
        flush_interval -1
    }
}

:80 {
    reverse_proxy https://localhost:3001 {
        transport http {
            tls_insecure_skip_verify
        }
        flush_interval -1
    }
}
